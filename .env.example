# 복사해서 .env 로 쓰세요. OAuth 로그인은 `python -m agent.main --login` 으로 하며,
# 아래 값들은 기본값이 있어 대개 건드릴 필요 없습니다.

# OAuth 토큰 저장 위치
# AGENT_AUTH_PATH=~/.dasan/auth.json

# Responses 백엔드 URL (문서화되지 않아 Codex 버전마다 다를 수 있음)
# AGENT_BASE_URL=https://chatgpt.com/backend-api/codex

# 모델명 (백엔드가 받는 값으로 맞춰야 함)
# AGENT_MODEL=gpt-5-codex

# 세션 DB 경로
# AGENT_DB_PATH=agent_sessions.db
